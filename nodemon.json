{
  "restartable": "rs",
  "verbose": true,
  "execMap": {
    "js": "electron ."
  },
  "watch": [
    "main.js",
    "preload.js",
    "lib/db.js",
    "lib/settings.js",
    "lib/twitter/",
    "lib/llm/",
    "renderer/",
    "index.html"
  ],
  "ext": "js,html",
  "ignore": [
    ".git",
    "node_modules",
    "lib/wiki/",
    "scripts/",
    "social-wiki/",
    "plans/",
    ".cache/",
    "out/",
    "docs/"
  ],
  "delay": "500",
  "signal": "SIGTERM",
  "env": {
    "NODE_ENV": "development"
  }
}
