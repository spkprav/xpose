{
  "name": "xpose",
  "version": "1.0.0",
  "description": "Electron desktop tool that crawls your X (Twitter) circle and turns it into a queryable Postgres + Obsidian wiki. No API keys. uses your logged-in browser session.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U ${PGUSER:-postgres} -d ${PGDATABASE:-xpose}",
    "db:migrate": "docker compose exec -T postgres psql -v ON_ERROR_STOP=1 -U ${PGUSER:-postgres} -d ${PGDATABASE:-xpose} < schema.sql",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "wiki:setup": "bash lib/wiki/setup-ollama.sh",
    "wiki:gen": "node lib/wiki/generate.js",
    "wiki:keywords": "node lib/wiki/extract-keywords.js",
    "wiki:flush": "node lib/wiki/flush-keywords.js"
  },
  "keywords": [
    "electron",
    "twitter",
    "x",
    "social-graph",
    "obsidian",
    "postgres"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.2",
    "nodemon": "^3.1.0",
    "playwright": "^1.43.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.6.1",
    "electron-fetch": "^1.9.1",
    "electron-reload": "^2.0.0-alpha.1",
    "fs": "^0.0.1-security",
    "lodash": "^4.17.21",
    "pg": "^8.17.2",
    "playwright-extra": "^4.3.6",
    "puppeteer": "^22.7.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
