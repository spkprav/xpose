# ── Standalone scripts (scripts/*.mjs, scripts/render-hairball.py) ─────
# These run via `node` or `python3` outside Electron and read env vars.
# Also consumed by docker-compose.yml when starting the local Postgres container.
# The Electron app does NOT use this file. configure DB inside the app (Settings panel).
PGHOST=localhost
PGPORT=54329
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=xpose

# ── Ollama (local LLM for wiki keyword/niche extraction) ──────────────
# Used by lib/wiki/extract-keywords.js and lib/wiki/classify-niche.js.
# Override host if running ollama on another machine or non-default port.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b
